{
  "expo": {
    "name": "quilt-calc",
    "slug": "quilt-calc",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/splash-icon.png",
    "scheme": "quiltcalc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andylvl.quilt-calc",
      "appleTeamId": "5K4K37877N"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.andylvl.quiltcalc"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#FDFDF6",
          "imageWidth": 430
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "264eedb8-d0fa-4317-a448-f626ef6b4553"
      }
    }
  }
}
